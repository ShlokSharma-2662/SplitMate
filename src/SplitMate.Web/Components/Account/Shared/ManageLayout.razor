@inherits LayoutComponentBase
@layout SplitMate.Web.Components.Layout.MainLayout

<MudText Typo="Typo.h5" Class="mb-2 font-weight-bold">Manage Account</MudText>
<MudText Typo="Typo.body2" Class="mb-6 text-muted">Manage your profile, email, password, and authentication settings.</MudText>

<MudGrid>
    <MudItem xs="12" md="3">
        <MudPaper Elevation="1" Class="pa-2">
            <ManageNavMenu />
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="9">
        <MudPaper Elevation="1" Class="pa-6">
            @Body
        </MudPaper>
    </MudItem>
</MudGrid>
