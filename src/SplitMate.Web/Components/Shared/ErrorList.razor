@if (Errors is { Count: > 0 })
{
    <div class="alert alert-danger" role="alert">
        <ul class="mb-0 ps-3">
            @foreach (var error in Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@code {
    [Parameter] public IReadOnlyList<string>? Errors { get; set; }
}
