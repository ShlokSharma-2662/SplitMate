@page "/groups/{GroupId:guid}/expenses/new"
@page "/groups/{GroupId:guid}/expenses/{ExpenseId:guid}/edit"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using MediatR
@using SplitMate.Application.Expenses
@using SplitMate.Application.Groups
@using SplitMate.Domain.Enums
@inject ISender Sender
@inject NavigationManager Navigation

<PageTitle>@(IsEdit ? "Edit expense" : "Add expense") - SplitMate</PageTitle>

<div class="mb-4">
    <MudBreadcrumbs Items="_breadcrumbs" Separator=">" Class="pa-0" />
</div>

<MudText Typo="Typo.h4" Class="mb-6 fw-bold">@(IsEdit ? "Edit Expense" : "Add Expense")</MudText>

<ErrorList Errors="errors" />

@if (group is null && errors.Count == 0)
{
    <div class="d-flex justify-center my-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (group is not null)
{
    <MudCard Elevation="1" Style="max-width: 720px;">
        <MudCardContent>
            <EditForm Model="model" OnValidSubmit="SubmitAsync" FormName="expense-form">
                <DataAnnotationsValidator />
                
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="model.Description" 
                                      Label="Description" 
                                      Placeholder="e.g. Dinner at beach shack" 
                                      Variant="Variant.Outlined" 
                                      For="() => model.Description" />
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal" @bind-Value="model.Amount" 
                                         Label="Amount" 
                                         Adornment="Adornment.Start" 
                                         AdornmentText="₹" 
                                         Variant="Variant.Outlined" 
                                         Step="0.01M"
                                         For="() => model.Amount" />
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudDatePicker @bind-Date="ModelDate" 
                                       Label="Date" 
                                       Editable="true"
                                       Variant="Variant.Outlined" />
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" @bind-Value="model.PaidByUserId" 
                                   Label="Paid by" 
                                   Variant="Variant.Outlined">
                            @foreach (var member in group.Members)
                            {
                                <MudSelectItem Value="@member.UserId">@member.DisplayName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudSelect T="SplitType" @bind-Value="model.SplitType" 
                                   Label="Split type" 
                                   Variant="Variant.Outlined">
                            <MudSelectItem Value="@SplitType.Equal">Equal</MudSelectItem>
                            <MudSelectItem Value="@SplitType.ExactAmounts">Exact amounts</MudSelectItem>
                            <MudSelectItem Value="@SplitType.Percentage">Percentage</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-2 fw-semibold">Split between</MudText>
                        
                        <MudSimpleTable Dense="true" Elevation="0" Style="max-width: 480px;" Outlined="true">
                            <tbody>
                                @foreach (var row in model.Rows)
                                {
                                    <tr>
                                        <td>
                                            <MudCheckBox T="bool" @bind-Value="row.Included" Label="@row.DisplayName" Color="Color.Primary" />
                                        </td>
                                        <td style="width: 160px;">
                                            @if (model.SplitType != SplitType.Equal)
                                            {
                                                <MudNumericField T="decimal?" @bind-Value="row.Value" 
                                                                 Disabled="@(!row.Included)" 
                                                                 Adornment="Adornment.Start" 
                                                                 AdornmentText="@(model.SplitType == SplitType.Percentage ? "%" : "₹")"
                                                                 Variant="Variant.Outlined" 
                                                                 Margin="Margin.Dense" 
                                                                 Step="0.01M" />
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                        
                        @if (model.SplitType == SplitType.ExactAmounts)
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1 d-block">
                                Exact shares must add up to the expense amount.
                            </MudText>
                        }
                        else if (model.SplitType == SplitType.Percentage)
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1 d-block">
                                Percentages must add up to 100.
                            </MudText>
                        }
                    </MudItem>
                    
                    <MudItem xs="12" Class="d-flex gap-2 mt-4">
                        <MudButton ButtonType="ButtonType.Submit" 
                                   Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   Disabled="@busy">
                            @if (busy)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <span class="ms-2">Processing...</span>
                            }
                            else
                            {
                                <span>@(IsEdit ? "Save changes" : "Add expense")</span>
                            }
                        </MudButton>
                        <MudButton href="@($"groups/{GroupId}")" 
                                   Variant="Variant.Outlined" 
                                   Color="Color.Secondary">
                            Cancel
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudCardContent>
    </MudCard>
}

@code {
    [Parameter] public Guid GroupId { get; set; }
    [Parameter] public Guid? ExpenseId { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool IsEdit => ExpenseId.HasValue;

    private GroupDetailDto? group;
    private FormModel model = new();
    private IReadOnlyList<string> errors = [];
    private bool busy;
    private string userId = string.Empty;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new BreadcrumbItem("My Groups", href: "groups"),
        new BreadcrumbItem(group?.Name ?? "Group", href: $"groups/{GroupId}"),
        new BreadcrumbItem(IsEdit ? "Edit Expense" : "Add Expense", href: null, disabled: true)
    };

    private DateTime? ModelDate
    {
        get => model.Date.ToDateTime(TimeOnly.MinValue);
        set => model.Date = value.HasValue ? DateOnly.FromDateTime(value.Value) : DateOnly.FromDateTime(DateTime.Today);
    }

    protected override async Task OnParametersSetAsync()
    {
        var auth = await AuthState!;
        userId = auth.User.GetUserId();

        var result = await Sender.Send(new GetGroupDetailQuery(GroupId, userId));
        if (!result.Succeeded)
        {
            errors = result.Errors;
            return;
        }

        group = result.Value!;
        model = new FormModel
        {
            PaidByUserId = userId,
            Date = DateOnly.FromDateTime(DateTime.Today),
            Rows = group.Members
                .Select(m => new ParticipantRow { UserId = m.UserId, DisplayName = m.DisplayName, Included = true })
                .ToList()
        };

        if (IsEdit)
        {
            var expense = group.Expenses.FirstOrDefault(e => e.Id == ExpenseId);
            if (expense is null)
            {
                errors = ["Expense not found in this group."];
                group = null;
                return;
            }

            model.Description = expense.Description;
            model.Amount = expense.Amount;
            model.PaidByUserId = expense.PaidByUserId;
            model.Date = expense.Date;
            model.SplitType = expense.SplitType;
            foreach (var row in model.Rows)
            {
                var share = expense.Shares.FirstOrDefault(s => s.UserId == row.UserId);
                row.Included = share is not null;
                row.Value = share is null ? null : expense.SplitType switch
                {
                    SplitType.ExactAmounts => share.ShareAmount,
                    SplitType.Percentage when expense.Amount != 0 =>
                        Math.Round(share.ShareAmount / expense.Amount * 100m, 2),
                    _ => null
                };
            }
        }
    }

    private async Task SubmitAsync()
    {
        busy = true;
        try
        {
            var participants = model.Rows
                .Where(r => r.Included)
                .Select(r => new SplitParticipantInput(
                    r.UserId, model.SplitType == SplitType.Equal ? null : r.Value))
                .ToList();

            Result result = IsEdit
                ? await Sender.Send(new UpdateExpenseCommand(
                    ExpenseId!.Value, GroupId, model.Description, model.Amount, model.PaidByUserId,
                    model.Date, model.SplitType, participants, userId))
                : await Sender.Send(new CreateExpenseCommand(
                    GroupId, model.Description, model.Amount, model.PaidByUserId,
                    model.Date, model.SplitType, participants, userId));

            if (result.Succeeded)
            {
                Navigation.NavigateTo($"groups/{GroupId}");
            }
            else
            {
                errors = result.Errors;
            }
        }
        finally
        {
            busy = false;
        }
    }

    private sealed class FormModel
    {
        [Required(ErrorMessage = "Description is required.")]
        [StringLength(200)]
        public string Description { get; set; } = string.Empty;

        [Range(0.01, 100_000_000, ErrorMessage = "Amount must be greater than zero.")]
        public decimal Amount { get; set; }

        public string PaidByUserId { get; set; } = string.Empty;
        public DateOnly Date { get; set; }
        public SplitType SplitType { get; set; } = SplitType.Equal;
        public List<ParticipantRow> Rows { get; set; } = [];
    }

    private sealed class ParticipantRow
    {
        public string UserId { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public bool Included { get; set; }
        public decimal? Value { get; set; }
    }
}
