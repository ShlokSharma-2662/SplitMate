@page "/groups/{GroupId:guid}/settle"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using MediatR
@using SplitMate.Application.Groups
@using SplitMate.Application.Settlements
@inject ISender Sender
@inject NavigationManager Navigation

<PageTitle>Settle up - SplitMate</PageTitle>

<div class="mb-4">
    <MudBreadcrumbs Items="_breadcrumbs" Separator=">" Class="pa-0" />
</div>

<MudText Typo="Typo.h4" Class="mb-2 fw-bold">Settle up</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Record a repayment between two members. You can lower the amount for a partial settlement.
</MudText>

<ErrorList Errors="errors" />

@if (group is null && errors.Count == 0)
{
    <div class="d-flex justify-center my-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (group is not null)
{
    <MudCard Elevation="1" Style="max-width: 560px;">
        <MudCardContent>
            <EditForm Model="model" OnValidSubmit="SubmitAsync" FormName="settle-up">
                <DataAnnotationsValidator />
                
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" @bind-Value="model.FromUserId" 
                                   Label="Who paid" 
                                   Variant="Variant.Outlined">
                            @foreach (var member in group.Members)
                            {
                                <MudSelectItem Value="@member.UserId">@member.DisplayName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" @bind-Value="model.ToUserId" 
                                   Label="Who received" 
                                   Variant="Variant.Outlined">
                            @foreach (var member in group.Members)
                            {
                                <MudSelectItem Value="@member.UserId">@member.DisplayName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal" @bind-Value="model.Amount" 
                                         Label="Amount" 
                                         Adornment="Adornment.Start" 
                                         AdornmentText="₹" 
                                         Variant="Variant.Outlined" 
                                         Step="0.01M"
                                         For="() => model.Amount" />
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudDatePicker @bind-Date="ModelDate" 
                                       Label="Date" 
                                       Editable="true"
                                       Variant="Variant.Outlined" />
                    </MudItem>
                    
                    <MudItem xs="12">
                        <MudTextField @bind-Value="model.Note" 
                                      Label="Note (optional)" 
                                      Placeholder="e.g. Paid via UPI" 
                                      Variant="Variant.Outlined" 
                                      For="() => model.Note" />
                    </MudItem>
                    
                    <MudItem xs="12" Class="d-flex gap-2 mt-4">
                        <MudButton ButtonType="ButtonType.Submit" 
                                   Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   Disabled="@busy">
                            @if (busy)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <span class="ms-2">Recording...</span>
                            }
                            else
                            {
                                <span>Record settlement</span>
                            }
                        </MudButton>
                        <MudButton href="@($"groups/{GroupId}/balances")" 
                                   Variant="Variant.Outlined" 
                                   Color="Color.Secondary">
                            Cancel
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudCardContent>
    </MudCard>
}

@code {
    [Parameter] public Guid GroupId { get; set; }
    [SupplyParameterFromQuery(Name = "from")] public string? From { get; set; }
    [SupplyParameterFromQuery(Name = "to")] public string? To { get; set; }
    [SupplyParameterFromQuery(Name = "amount")] public decimal? Amount { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private GroupDetailDto? group;
    private FormModel model = new();
    private IReadOnlyList<string> errors = [];
    private bool busy;
    private string userId = string.Empty;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new BreadcrumbItem("My Groups", href: "groups"),
        new BreadcrumbItem(group?.Name ?? "Group", href: $"groups/{GroupId}"),
        new BreadcrumbItem("Settle up", href: null, disabled: true)
    };

    private DateTime? ModelDate
    {
        get => model.Date.ToDateTime(TimeOnly.MinValue);
        set => model.Date = value.HasValue ? DateOnly.FromDateTime(value.Value) : DateOnly.FromDateTime(DateTime.Today);
    }

    protected override async Task OnParametersSetAsync()
    {
        var auth = await AuthState!;
        userId = auth.User.GetUserId();

        var result = await Sender.Send(new GetGroupDetailQuery(GroupId, userId));
        if (!result.Succeeded)
        {
            errors = result.Errors;
            return;
        }

        group = result.Value!;
        model = new FormModel
        {
            FromUserId = From ?? userId,
            ToUserId = To ?? group.Members.Select(m => m.UserId).FirstOrDefault(id => id != userId) ?? string.Empty,
            Amount = Amount ?? 0m,
            Date = DateOnly.FromDateTime(DateTime.Today)
        };
    }

    private async Task SubmitAsync()
    {
        busy = true;
        try
        {
            var result = await Sender.Send(new CreateSettlementCommand(
                GroupId, model.FromUserId, model.ToUserId, model.Amount,
                model.Date, model.Note, userId));

            if (result.Succeeded)
            {
                Navigation.NavigateTo($"groups/{GroupId}/balances");
            }
            else
            {
                errors = result.Errors;
            }
        }
        finally
        {
            busy = false;
        }
    }

    private sealed class FormModel
    {
        public string FromUserId { get; set; } = string.Empty;
        public string ToUserId { get; set; } = string.Empty;

        [Range(0.01, 100_000_000, ErrorMessage = "Amount must be greater than zero.")]
        public decimal Amount { get; set; }

        public DateOnly Date { get; set; }

        [StringLength(200)]
        public string? Note { get; set; }
    }
}
