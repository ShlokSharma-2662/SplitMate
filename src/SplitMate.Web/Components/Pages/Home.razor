@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@using MediatR
@using SplitMate.Application.Dashboard
@inject ISender Sender

<PageTitle>Dashboard - SplitMate</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6 fw-bold">Dashboard</MudText>

<ErrorList Errors="errors" />

@if (summary is null && errors.Count == 0)
{
    <div class="d-flex justify-center my-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (summary is not null)
{
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-4 border-l-4 border-error" Style="border-left: 6px solid var(--mud-palette-error) !important;" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary mb-1">Total you owe</MudText>
                <MudText Typo="Typo.h4" Color="Color.Error" Class="fw-bold">
                    @MoneyFormat.Inr(summary.TotalIOwe)
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-4" Style="border-left: 6px solid var(--mud-palette-success) !important;" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary mb-1">Total you are owed</MudText>
                <MudText Typo="Typo.h4" Color="Color.Success" Class="fw-bold">
                    @MoneyFormat.Inr(summary.TotalIAmOwed)
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-4" Style="@($"border-left: 6px solid {(NetBalance > 0 ? "var(--mud-palette-success)" : NetBalance < 0 ? "var(--mud-palette-error)" : "var(--mud-palette-text-secondary)")} !important;")" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary mb-1">Net balance</MudText>
                <MudText Typo="Typo.h4" Class="fw-bold" Color="@(NetBalance > 0 ? Color.Success : NetBalance < 0 ? Color.Error : Color.Default)">
                    @MoneyFormat.Inr(NetBalance)
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h5" Class="mb-4 fw-semibold">Recent Activity</MudText>
    
    @if (summary.RecentActivity.Count == 0)
    {
        <MudPaper Class="pa-6 text-center" Elevation="1">
            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Large" Color="Color.Info" Class="mb-2" />
            <MudText Typo="Typo.body1" Class="mud-text-secondary mb-3">No activity yet.</MudText>
            <MudButton href="groups" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">
                Create a Group
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="1">
            <MudList T="ActivityItemDto">
                @foreach (var item in summary.RecentActivity)
                {
                    <MudListItem href="@($"groups/{item.GroupId}")" Icon="@(item.Type == ActivityType.Expense ? Icons.Material.Filled.ReceiptLong : Icons.Material.Filled.Handshake)" IconColor="@(item.Type == ActivityType.Expense ? Color.Primary : Color.Secondary)">
                        <div class="d-flex justify-space-between align-center w-100 flex-wrap">
                            <div>
                                <div class="d-flex align-center gap-2">
                                    <MudText Typo="Typo.body1" Class="fw-semibold">@item.Title</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@(item.Type == ActivityType.Expense ? Color.Primary : Color.Secondary)" Variant="Variant.Text">
                                        @(item.Type == ActivityType.Expense ? "Expense" : "Settlement")
                                    </MudChip>
                                </div>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@item.Subtitle</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@item.GroupName · @item.Date.ToString("dd MMM yyyy")</MudText>
                            </div>
                            <MudText Typo="Typo.body1" Class="fw-bold">@MoneyFormat.Inr(item.Amount)</MudText>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        </MudPaper>
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private DashboardSummaryDto? summary;
    private IReadOnlyList<string> errors = [];

    private decimal NetBalance => summary is not null ? summary.TotalIAmOwed - summary.TotalIOwe : 0m;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState!;
        var result = await Sender.Send(new GetDashboardSummaryQuery(auth.User.GetUserId()));
        if (result.Succeeded)
        {
            summary = result.Value;
        }
        else
        {
            errors = result.Errors;
        }
    }
}
