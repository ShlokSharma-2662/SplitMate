@page "/groups"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using MediatR
@using SplitMate.Application.Groups
@inject ISender Sender
@inject ISnackbar Snackbar

<PageTitle>My Groups - SplitMate</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6 fw-bold">My Groups</MudText>

<MudCard Class="mb-6" Elevation="1">
    <MudCardContent>
        <MudText Typo="Typo.h6" Class="mb-3">Create a new group</MudText>
        <ErrorList Errors="createErrors" />
        
        <EditForm Model="newGroup" OnValidSubmit="CreateGroupAsync" FormName="create-group">
            <DataAnnotationsValidator />
            <div class="d-flex align-start gap-4 flex-wrap flex-sm-nowrap">
                <div class="flex-grow-1 w-100">
                    <MudTextField @bind-Value="newGroup.Name" 
                                  Label="Group Name" 
                                  Placeholder="e.g. Goa Trip, Flatmates" 
                                  Variant="Variant.Outlined" 
                                  Margin="Margin.Dense" 
                                  For="() => newGroup.Name" />
                </div>
                <div class="mt-1">
                    <MudButton ButtonType="ButtonType.Submit" 
                               Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               Disabled="@busy" 
                               Size="Size.Medium">
                        @if (busy)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                            <span class="ms-2">Creating...</span>
                        }
                        else
                        {
                            <span>Create</span>
                        }
                    </MudButton>
                </div>
            </div>
        </EditForm>
    </MudCardContent>
</MudCard>

<ErrorList Errors="loadErrors" />

@if (groups is null && loadErrors.Count == 0)
{
    <div class="d-flex justify-center my-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (groups is { Count: 0 })
{
    <MudPaper Class="pa-6 text-center" Elevation="1">
        <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Large" Color="Color.Default" Class="mb-2" />
        <MudText Typo="Typo.body1" Class="mud-text-secondary">You are not in any groups yet. Create one above to get started.</MudText>
    </MudPaper>
}
else if (groups is not null)
{
    <MudGrid>
        @foreach (var group in groups)
        {
            <MudItem xs="12" sm="6" md="4">
                <a href="@($"groups/{group.Id}")" style="text-decoration: none;">
                    <MudCard Class="h-100 mud-ripple" Elevation="1">
                        <MudCardContent Class="d-flex align-center gap-4">
                            <MudAvatar Color="Color.Primary" Size="Size.Large">
                                @group.Name[..1].ToUpper()
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.h6" Class="fw-semibold">@group.Name</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                    @group.MemberCount member@(group.MemberCount == 1 ? "" : "s")
                                </MudText>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </a>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private IReadOnlyList<GroupSummaryDto>? groups;
    private IReadOnlyList<string> loadErrors = [];
    private IReadOnlyList<string> createErrors = [];
    private NewGroupModel newGroup = new();
    private bool busy;
    private string userId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState!;
        userId = auth.User.GetUserId();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var result = await Sender.Send(new GetMyGroupsQuery(userId));
        if (result.Succeeded)
        {
            groups = result.Value;
        }
        else
        {
            loadErrors = result.Errors;
        }
    }

    private async Task CreateGroupAsync()
    {
        busy = true;
        try
        {
            var result = await Sender.Send(new CreateGroupCommand(newGroup.Name, userId));
            if (result.Succeeded)
            {
                createErrors = [];
                Snackbar.Add($"Group '{newGroup.Name}' created successfully!", Severity.Success);
                newGroup = new NewGroupModel();
                await LoadAsync();
            }
            else
            {
                createErrors = result.Errors;
            }
        }
        finally
        {
            busy = false;
        }
    }

    private sealed class NewGroupModel
    {
        [Required(ErrorMessage = "Group name is required.")]
        [StringLength(100)]
        public string Name { get; set; } = string.Empty;
    }
}
