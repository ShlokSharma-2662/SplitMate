@page "/groups"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using MediatR
@using SplitMate.Application.Groups
@inject ISender Sender

<PageTitle>My Groups - SplitMate</PageTitle>

<h1>My Groups</h1>

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h5 card-title">Create a group</h2>
        <ErrorList Errors="createErrors" />
        <EditForm Model="newGroup" OnValidSubmit="CreateGroupAsync" FormName="create-group">
            <DataAnnotationsValidator />
            <div class="row g-2 align-items-start">
                <div class="col-sm-8 col-md-6">
                    <InputText @bind-Value="newGroup.Name" class="form-control" placeholder="e.g. Goa Trip" />
                    <ValidationMessage For="() => newGroup.Name" class="text-danger" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary" disabled="@busy">Create</button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

<ErrorList Errors="loadErrors" />

@if (groups is null && loadErrors.Count == 0)
{
    <p><em>Loading…</em></p>
}
else if (groups is { Count: 0 })
{
    <p class="text-muted">You are not in any groups yet. Create one above to get started.</p>
}
else if (groups is not null)
{
    <div class="row g-3">
        @foreach (var group in groups)
        {
            <div class="col-sm-6 col-lg-4">
                <a href="groups/@group.Id" class="card h-100 text-decoration-none">
                    <div class="card-body">
                        <h3 class="h5 card-title mb-1">@group.Name</h3>
                        <span class="text-muted">@group.MemberCount member@(group.MemberCount == 1 ? "" : "s")</span>
                    </div>
                </a>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private IReadOnlyList<GroupSummaryDto>? groups;
    private IReadOnlyList<string> loadErrors = [];
    private IReadOnlyList<string> createErrors = [];
    private NewGroupModel newGroup = new();
    private bool busy;
    private string userId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState!;
        userId = auth.User.GetUserId();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var result = await Sender.Send(new GetMyGroupsQuery(userId));
        if (result.Succeeded)
        {
            groups = result.Value;
        }
        else
        {
            loadErrors = result.Errors;
        }
    }

    private async Task CreateGroupAsync()
    {
        busy = true;
        try
        {
            var result = await Sender.Send(new CreateGroupCommand(newGroup.Name, userId));
            if (result.Succeeded)
            {
                createErrors = [];
                newGroup = new NewGroupModel();
                await LoadAsync();
            }
            else
            {
                createErrors = result.Errors;
            }
        }
        finally
        {
            busy = false;
        }
    }

    private sealed class NewGroupModel
    {
        [Required(ErrorMessage = "Group name is required.")]
        [StringLength(100)]
        public string Name { get; set; } = string.Empty;
    }
}
