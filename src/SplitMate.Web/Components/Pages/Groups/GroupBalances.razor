@page "/groups/{GroupId:guid}/balances"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Globalization
@using MediatR
@using SplitMate.Application.Balances
@inject ISender Sender

<PageTitle>Balances - SplitMate</PageTitle>

<div class="mb-4">
    <MudBreadcrumbs Items="_breadcrumbs" Separator=">" Class="pa-0" />
</div>

<MudText Typo="Typo.h4" Class="mb-6 fw-bold">Balances</MudText>

<ErrorList Errors="errors" />

@if (balances is null && errors.Count == 0)
{
    <div class="d-flex justify-center my-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (balances is not null)
{
    <MudGrid>
        <MudItem xs="12" lg="5">
            <MudCard Elevation="1">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="fw-semibold">Net Balances</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudList T="MemberBalanceDto">
                        @foreach (var member in balances.MemberBalances)
                        {
                            <MudListItem Icon="@Icons.Material.Filled.Person" IconColor="Color.Default">
                                <div class="d-flex justify-space-between align-center w-100 flex-wrap">
                                    <MudText Typo="Typo.body1" Class="fw-medium">@member.DisplayName</MudText>
                                    @if (member.NetBalance > 0)
                                    {
                                        <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">
                                            gets back @MoneyFormat.Inr(member.NetBalance)
                                        </MudChip>
                                    }
                                    else if (member.NetBalance < 0)
                                    {
                                        <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled">
                                            owes @MoneyFormat.Inr(-member.NetBalance)
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Text">
                                            settled up
                                        </MudChip>
                                    }
                                </div>
                            </MudListItem>
                            <MudDivider />
                        }
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" lg="7">
            <MudCard Elevation="1">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="fw-semibold">Suggested Settlements</MudText>
                        @if (balances.SimplifiedDebts.Count > 0)
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                Simplified with at most @(balances.MemberBalances.Count - 1) payments.
                            </MudText>
                        }
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (balances.SimplifiedDebts.Count == 0)
                    {
                        <div class="text-center py-6">
                            <MudIcon Icon="@Icons.Material.Filled.Celebration" Size="Size.Large" Color="Color.Success" Class="mb-2" />
                            <MudText Typo="Typo.body1" Class="mud-text-secondary">Everyone is settled up. 🎉</MudText>
                        </div>
                    }
                    else
                    {
                        <MudSimpleTable Hover="true">
                            <thead>
                                <tr>
                                    <th>From</th>
                                    <th>To</th>
                                    <th class="text-right">Amount</th>
                                    <th class="text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var debt in balances.SimplifiedDebts)
                                {
                                    <tr>
                                        <td>
                                            <MudText Color="Color.Error" Typo="Typo.body2" Class="fw-medium">@debt.FromDisplayName</MudText>
                                        </td>
                                        <td>
                                            <MudText Color="Color.Success" Typo="Typo.body2" Class="fw-medium">@debt.ToDisplayName</MudText>
                                        </td>
                                        <td class="text-right fw-semibold">@MoneyFormat.Inr(debt.Amount)</td>
                                        <td class="text-right">
                                            <MudButton href="@SettleUrl(debt)" 
                                                       Variant="Variant.Filled" 
                                                       Color="Color.Primary" 
                                                       Size="Size.Small">
                                                Settle up
                                            </MudButton>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid GroupId { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private GroupBalancesDto? balances;
    private IReadOnlyList<string> errors = [];

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new BreadcrumbItem("My Groups", href: "groups"),
        new BreadcrumbItem(balances?.GroupName ?? "Group", href: $"groups/{GroupId}"),
        new BreadcrumbItem("Balances", href: null, disabled: true)
    };

    protected override async Task OnParametersSetAsync()
    {
        var auth = await AuthState!;
        var result = await Sender.Send(new GetGroupBalancesQuery(GroupId, auth.User.GetUserId()));
        if (result.Succeeded)
        {
            balances = result.Value;
            errors = [];
        }
        else
        {
            balances = null;
            errors = result.Errors;
        }
    }

    private string SettleUrl(SimplifiedDebtDto debt) =>
        $"groups/{GroupId}/settle" +
        $"?from={Uri.EscapeDataString(debt.FromUserId)}" +
        $"&to={Uri.EscapeDataString(debt.ToUserId)}" +
        $"&amount={debt.Amount.ToString(CultureInfo.InvariantCulture)}";
}
