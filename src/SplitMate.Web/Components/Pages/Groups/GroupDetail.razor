@page "/groups/{GroupId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using MediatR
@using SplitMate.Application.Expenses
@using SplitMate.Application.Groups
@using SplitMate.Domain.Enums
@inject ISender Sender
@inject IJSRuntime Js
@inject ISnackbar Snackbar

<PageTitle>@(group?.Name ?? "Group") - SplitMate</PageTitle>

<div class="mb-4">
    <MudBreadcrumbs Items="_breadcrumbs" Separator=">" Class="pa-0" />
</div>

<ErrorList Errors="loadErrors" />

@if (group is null && loadErrors.Count == 0)
{
    <div class="d-flex justify-center my-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (group is not null)
{
    <div class="d-flex flex-wrap justify-space-between align-center mb-6 gap-4">
        <MudText Typo="Typo.h4" Class="fw-bold">@group.Name</MudText>
        <div class="d-flex gap-2">
            <MudButton href="@($"groups/{group.Id}/balances")" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AccountBalanceWallet">
                View Balances
            </MudButton>
            <MudButton href="@($"groups/{group.Id}/expenses/new")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddCard">
                Add Expense
            </MudButton>
        </div>
    </div>

    <MudGrid>
        <MudItem xs="12" lg="4">
            <MudCard Elevation="1" Class="mb-6">
                <MudCardHeader Class="pb-2">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="fw-semibold">Members (@group.Members.Count)</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudList T="GroupMemberDto">
                        @foreach (var member in group.Members)
                        {
                            <MudListItem Icon="@Icons.Material.Filled.Person" IconColor="Color.Secondary">
                                <div class="d-flex flex-column">
                                    <MudText Typo="Typo.body1" Class="fw-medium">@member.DisplayName</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@member.Email</MudText>
                                </div>
                            </MudListItem>
                            <MudDivider />
                        }
                    </MudList>
                </MudCardContent>
                <MudCardContent Class="border-top pa-4">
                    <MudText Typo="Typo.subtitle2" Class="mb-2 fw-semibold">Add member by email</MudText>
                    <ErrorList Errors="addMemberErrors" />
                    
                    <EditForm Model="newMember" OnValidSubmit="AddMemberAsync" FormName="add-member">
                        <DataAnnotationsValidator />
                        <div class="d-flex align-start gap-2 mt-2 w-100">
                            <div class="flex-grow-1">
                                <MudTextField @bind-Value="newMember.Email" 
                                              Label="Email Address" 
                                              Placeholder="friend@example.com" 
                                              Variant="Variant.Outlined" 
                                              Margin="Margin.Dense" 
                                              For="() => newMember.Email" />
                            </div>
                            <MudButton ButtonType="ButtonType.Submit" 
                                       Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       Disabled="@busy" 
                                       Class="mt-1">
                                @if (busy)
                                {
                                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                    <span class="ms-2">Adding...</span>
                                }
                                else
                                {
                                    <span>Add</span>
                                }
                            </MudButton>
                        </div>
                    </EditForm>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" lg="8">
            <MudCard Elevation="1">
                <MudCardHeader Class="pb-2">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="fw-semibold">Expenses</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <ErrorList Errors="expenseErrors" />
                    
                    @if (group.Expenses.Count == 0)
                    {
                        <div class="text-center py-6">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Large" Color="Color.Default" Class="mb-2" />
                            <MudText Typo="Typo.body1" Class="mud-text-secondary mb-3">No expenses yet. Add the first one!</MudText>
                        </div>
                    }
                    else
                    {
                        <MudSimpleTable Hover="true" Striped="false" Style="overflow-x: auto;">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Description</th>
                                    <th>Paid by</th>
                                    <th>Split</th>
                                    <th class="text-right">Amount</th>
                                    <th class="text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var expense in group.Expenses)
                                {
                                    <tr>
                                        <td class="text-nowrap">@expense.Date.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <details>
                                                <summary class="fw-medium text-primary" style="cursor: pointer;">@expense.Description</summary>
                                                <div class="mt-2 pa-2 mud-background-gray rounded">
                                                    @foreach (var share in expense.Shares)
                                                    {
                                                        <div class="d-flex justify-space-between py-1">
                                                            <MudText Typo="Typo.caption">@share.DisplayName</MudText>
                                                            <MudText Typo="Typo.caption" Class="fw-semibold">@MoneyFormat.Inr(share.ShareAmount)</MudText>
                                                        </div>
                                                    }
                                                </div>
                                            </details>
                                        </td>
                                        <td>@expense.PaidByDisplayName</td>
                                        <td>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">
                                                @SplitLabel(expense.SplitType)
                                            </MudChip>
                                        </td>
                                        <td class="text-right fw-semibold">@MoneyFormat.Inr(expense.Amount)</td>
                                        <td class="text-right text-nowrap">
                                            @if (expense.PaidByUserId == userId)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                                               Size="Size.Small" 
                                                               Color="Color.Default" 
                                                               href="@($"groups/{group.Id}/expenses/{expense.Id}/edit")" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                               Size="Size.Small" 
                                                               Color="Color.Error" 
                                                               Disabled="@busy" 
                                                               OnClick="() => DeleteExpenseAsync(expense.Id)" />
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid GroupId { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private GroupDetailDto? group;
    private IReadOnlyList<string> loadErrors = [];
    private IReadOnlyList<string> addMemberErrors = [];
    private IReadOnlyList<string> expenseErrors = [];
    private NewMemberModel newMember = new();
    private bool busy;
    private string userId = string.Empty;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new BreadcrumbItem("My Groups", href: "groups"),
        new BreadcrumbItem(group?.Name ?? "Group Details", href: null, disabled: true)
    };

    protected override async Task OnParametersSetAsync()
    {
        var auth = await AuthState!;
        userId = auth.User.GetUserId();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var result = await Sender.Send(new GetGroupDetailQuery(GroupId, userId));
        if (result.Succeeded)
        {
            group = result.Value;
            loadErrors = [];
        }
        else
        {
            group = null;
            loadErrors = result.Errors;
        }
    }

    private async Task AddMemberAsync()
    {
        busy = true;
        try
        {
            var result = await Sender.Send(new AddMemberCommand(GroupId, newMember.Email, userId));
            if (result.Succeeded)
            {
                addMemberErrors = [];
                Snackbar.Add($"{newMember.Email.Trim()} successfully added to the group!", Severity.Success);
                newMember = new NewMemberModel();
                await LoadAsync();
            }
            else
            {
                addMemberErrors = result.Errors;
            }
        }
        finally
        {
            busy = false;
        }
    }

    private async Task DeleteExpenseAsync(Guid expenseId)
    {
        var confirmed = await Js.InvokeAsync<bool>("confirm", "Delete this expense? This cannot be undone.");
        if (!confirmed)
        {
            return;
        }

        busy = true;
        try
        {
            var result = await Sender.Send(new DeleteExpenseCommand(expenseId, userId));
            expenseErrors = result.Succeeded ? [] : result.Errors;
            if (result.Succeeded)
            {
                Snackbar.Add("Expense deleted successfully.", Severity.Success);
                await LoadAsync();
            }
        }
        finally
        {
            busy = false;
        }
    }

    private static string SplitLabel(SplitType splitType) => splitType switch
    {
        SplitType.Equal => "Equal",
        SplitType.ExactAmounts => "Exact amounts",
        SplitType.Percentage => "Percentage",
        _ => splitType.ToString()
    };

    private sealed class NewMemberModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;
    }
}
